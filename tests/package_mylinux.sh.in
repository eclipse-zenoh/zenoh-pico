#!/usr/bin/env bash
set -euo pipefail

SOURCE_DIR="@PROJECT_SOURCE_DIR@"
WORK_DIR="$(mktemp -d /tmp/zenoh-pico-package-mylinux-XXXXXX)"
trap 'rm -rf "$WORK_DIR"' EXIT

PREFIX_DIR="$WORK_DIR/prefix"
PACKAGE_DIR="$PREFIX_DIR/lib/cmake/zenohpico-mylinux"
PLATFORM_DIR="$PACKAGE_DIR/platforms"
BUILD_DIR="$WORK_DIR/build"

mkdir -p "$PLATFORM_DIR"

cat >"$PLATFORM_DIR/mylinux.cmake" <<'EOF'
zp_platform_set_network(mylinux)
zp_platform_set_tcp_backend(tcp_posix)
zp_platform_set_udp_backend(posix)
zp_platform_set_serial_backend(uart_mylinux)
EOF

cat >"$PACKAGE_DIR/zenohpico-mylinuxConfig.cmake" <<EOF
if(COMMAND zp_add_platform_dir)
  zp_add_platform_dir("\${CMAKE_CURRENT_LIST_DIR}/platforms")
endif()

if(NOT TARGET zenohpico::system_mylinux)
  add_library(zenohpico::system_mylinux INTERFACE IMPORTED GLOBAL)
  set_property(TARGET zenohpico::system_mylinux PROPERTY
               INTERFACE_SOURCES
               "${SOURCE_DIR}/src/system/unix/system.c")
  set_property(TARGET zenohpico::system_mylinux PROPERTY
               INTERFACE_COMPILE_DEFINITIONS
               "ZENOH_LINUX")
endif()
zp_register_system_layer(NAME mylinux TARGET zenohpico::system_mylinux)

if(NOT TARGET zenohpico::network_mylinux)
  add_library(zenohpico::network_mylinux INTERFACE IMPORTED GLOBAL)
endif()
zp_register_network(NAME mylinux TARGET zenohpico::network_mylinux SOCKET_COMPONENT posix)

if(NOT TARGET zenohpico::serial_backend_uart_mylinux)
  add_library(zenohpico::serial_backend_uart_mylinux INTERFACE IMPORTED GLOBAL)
  set_property(TARGET zenohpico::serial_backend_uart_mylinux PROPERTY
               INTERFACE_SOURCES
               "${SOURCE_DIR}/src/link/backend/rawio/tty_posix.c")
  set_property(TARGET zenohpico::serial_backend_uart_mylinux PROPERTY
               ZP_BACKEND_SYMBOL
               _z_tty_posix_rawio_ops)
endif()
zp_register_serial_backend(
  NAME uart_mylinux
  TARGET zenohpico::serial_backend_uart_mylinux
  SYMBOL _z_tty_posix_rawio_ops
)
EOF

cmake -S "$SOURCE_DIR" -B "$BUILD_DIR" \
  -DBUILD_EXAMPLES=OFF \
  -DZP_EXTERNAL_PACKAGES=zenohpico-mylinux \
  -DCMAKE_PREFIX_PATH="$PREFIX_DIR" \
  -DZP_PLATFORM=mylinux

cmake --build "$BUILD_DIR" -j --target \
  z_endpoint_test \
  z_tls_test \
  z_executor_test \
  z_background_executor_test \
  z_local_loopback_test

ctest --test-dir "$BUILD_DIR" --output-on-failure \
  -R '^z_endpoint_test$|^z_tls_test$|^z_executor_test$|^z_background_executor_test$|^z_local_loopback_test$' \
  --timeout 420
